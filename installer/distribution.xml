<?xml version="1.0" encoding="utf-8"?>
<installer-gui-script minSpecVersion="2">
    <title>桌面待办 v1.5</title>
    <welcome language="zh_CN" mime-type="text/plain"><![CDATA[欢迎安装「桌面待办」v1.5

一款简洁高效的桌面待办事项应用。

点击「继续」开始安装。]]></welcome>
    <welcome language="en" mime-type="text/plain"><![CDATA[Welcome to Desktop Todo v1.5

A clean and efficient desktop todo application.

Click "Continue" to start installation.]]></welcome>
    <options customize="allow" require-scripts="false" rootVolumeOnly="false" />
    <domains enable_anywhere="true" enable_currentUserHome="true" enable_localSystem="true" />
    <choices-outline>
        <line choice="default">
            <line choice="com.desktoptodo.app.pkg"/>
        </line>
    </choices-outline>
    <choice id="default"/>
    <choice id="com.desktoptodo.app.pkg" visible="false">
        <pkg-ref id="com.desktoptodo.app.pkg"/>
    </choice>
    <pkg-ref id="com.desktoptodo.app.pkg" version="1.5.0" onConclusion="none">DesktopTodo.pkg</pkg-ref>
</installer-gui-script>
